<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_coupon_create_wizard_form" model="ir.ui.view">
        <field name="name">partner.coupon.create.wizard.form</field>
        <field name="model">partner.coupon.create.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Coupon">
                <group>
                    <group>
                        <field name="partner_id"/>
                        <field name="name"/>
                        <field name="currency_id" domain="[('partner_id', '=', partner_id)]"/>
                        <field name="value"/>
                        <field name="code_source"/>
                    </group>
                    <group>
                        <field name="image_file" widget="image" string="Image" options="{'size': [128, 128]}"/>
                        <field name="image" invisible="1"/>
                    </group>
                </group>
                <group>
                    <field name="term_and_condition"/>
                </group>
                <group string="Generate Codes" invisible="code_source != 'generate'">
                    <field name="code_quantity"/>
                    <field name="prefix_code"/>
                    <field name="random_range"/>
                    <field name="suffix_code"/>
                    <div class="text-muted" colspan="2">
                        สามารถ generate ได้สูงสุด 2,000 code ต่อครั้ง
                    </div>
                </group>
                <group string="Import Codes" invisible="code_source != 'import'">
                    <button name="action_download_import_template" string="Download Template" type="object" class="btn-link" icon="fa-download"/>
                    <field name="import_file" filename="import_filename"/>
                    <field name="import_filename" invisible="1"/>
                    <div class="text-muted" colspan="2">
                        สามารถ import ได้สูงสุด 2,000 code ต่อครั้ง
                    </div>
                </group>
                <group string="Availability">
                    <field name="start_time"/>
                    <field name="code_expiry_interval"/>
                    <field name="end_time"/>
                </group>
                <footer>
                    <button name="action_create" string="Create" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
