<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_model_form" model="ir.ui.view">
        <field name="name">partner.form</field>
        <field name="model">partner</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_generate_redeem" string="Generate Redeem" type="object" class="btn-primary"/>
                    <button name="action_generate_coupon" string="Generate Coupon" type="object" class="btn-secondary"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <div class="oe_title">
                                <div class="text-muted" invisible="name == '' or not name">Partner</div>
                                <h1 invisible="not active or name == '' or not name">
                                    <field name="name" readonly="1"/>
                                </h1>
                                <h1 class="text-decoration-line-through text-muted" invisible="active or name == '' or not name">
                                    <field name="name" readonly="1"/>
                                </h1>
                            </div>
                        </group>
                        <group>
                            <field nolabel="1" name="logo_file" widget="image" class="oe_avatar" options="{'size': [128, 128]}"/>
                            <field name="logo" invisible="1"/>
                        </group>
                    </group>

                    <group>
                        <field name="liff_setup_url" readonly="1"/>
                    </group>

                    <group>
                        <group string="General Information">
                            <field name="name"/>
                            <field name="slug"/>
                            <field name="ui_crm_required_phone"/>
                            <field name="ui_crm_required_email"/>
                        </group>
                        <group string="Line Setting">
                            <field name="partner_line_liff_id"/>
                            <field name="partner_line_channel_access_token"/>
                        </group>
                    </group>

                    <notebook>
                          <page string="UI Config">
                            <group>
                                <field name="ui_banner_file" widget="image" string="Banner" options="{'size': [128, 128]}"/>
                                <field name="ui_banner" invisible="1"/>
                                <field name="ui_background_color"/>
                                <field name="ui_background_white_color"/>
                                <field name="ui_primary_color"/>
                                <field name="ui_secondary_color"/>
                                <field name="ui_surface_color"/>

                                <field name="ui_text_color"/>
                                <field name="ui_text_white_color"/>
                                <field name="ui_text_gray_color"/>
                                <field name="ui_text_success_color"/>
                                <field name="ui_text_error_color"/>

                                <field name="ui_button_color"/>
                                <field name="ui_button_text_color"/>

                                <field name="ui_welcome_title"/>
                            </group>
                        </page>
                        <page string="UI Custom Fields">
                            <field name="ui_custom_field_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="key"/>
                                    <field name="value"/>
                                </list>
                            </field>
                        </page>
                        <page string="Ads">
                            <field name="ads_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="image_file" widget="image" string="Image" options="{'size': [128, 128]}" width="128"/>
                                    <field name="image" column_invisible="1"/>
                                    <field name="message"/>
                                    <field name="action"/>
                                    <field name="start_date"/>
                                    <field name="end_date"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                        <page string="Users">
                            <field name="user_search" placeholder="ค้นหาชื่อ, LINE ID, email, เบอร์โทร..." nolabel="1" width="300"/>
                            <field name="filtered_user_ids" nolabel="1">
                                <list delete="0" create="0">
                                    <field name="display_name"/>
                                    <field name="line_user_id"/>
                                    <field name="tier_id"/>
                                    <button name="action_open_user" type="object" string="Open" icon="fa-external-link"/>
                                    <button name="action_add_point" type="object" string="Add Point" icon="fa-plus"/>
                                    <button name="action_add_coupon" type="object" string="Add Coupon" icon="fa-ticket"/>
                                </list>
                            </field>
                        </page>
                        <page string="Currencies">
                            <field name="currency_ids" nolabel="1">
                                <list editable="bottom" delete="0">
                                    <field name="name"/>
                                    <field name="is_default"/>
                                    <field name="is_total_spending"/>
                                </list>
                            </field>
                        </page>
                        <page string="Tiers">
                            <field name="tier_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="icon_file" widget="image" string="Logo" options="{'size': [64, 64]}" width="64"/>
                                    <field name="icon" column_invisible="1"/>
                                    <field name="name" width="200"/>
                                    <field name="code" width="200"/>
                                    <field name="color" width="200"/>
                                    <field name="min_spending"/>
                                    <field name="max_spending"/>
                                    <field name="convert_points"/>
                                    <field name="is_show_in_ui"/>
                                </list>
                            </field>
                        </page>
                        <page string="Redeem QR">
                            <field name="point_redeem_ids" nolabel="1">
                                <list delete="0">
                                    <field name="name"/>
                                    <field name="currency_id"/>
                                    <field name="value"/>
                                    <field name="type"/>
                                    <field name="expiration_date"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                        <page string="Coupons">
                            <field name="coupon_ids" nolabel="1">
                                <list delete="0" create="0">
                                    <field name="name"/>
                                    <field name="code_source"/>
                                    <field name="currency_id"/>
                                    <field name="value"/>
                                    <field name="total_code_count"/>
                                    <field name="available_code_count"/>
                                    <field name="redeemed_count"/>
                                    <field name="start_time"/>
                                    <field name="end_time"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids" options="{'post_refresh': 'recipients'}"/>
                </chatter>
            </form>
        </field>
    </record>
</odoo>
