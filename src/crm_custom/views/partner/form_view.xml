<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_model_form" model="ir.ui.view">
        <field name="name">partner.form</field>
        <field name="model">partner</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_generate_redeem" string="Generate Redeem" type="object" class="btn-primary"/>
                    <button name="action_generate_coupon" string="Generate Coupon" type="object" class="btn-secondary"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <div class="oe_title">
                                <div class="text-muted" invisible="name == '' or not name">Partner</div>
                                <h1 invisible="not active or name == '' or not name">
                                    <field name="name" readonly="1"/>
                                </h1>
                                <h1 class="text-decoration-line-through text-muted" invisible="active or name == '' or not name">
                                    <field name="name" readonly="1"/>
                                </h1>
                            </div>
                        </group>
                        <group>
                            <field nolabel="1" name="logo" widget="image" class="oe_avatar" options="{'size': [128, 128]}"/>
                        </group>
                    </group>

                    <group>
                        <field name="liff_setup_url" readonly="1"/>
                    </group>

                    <group>
                        <group string="General Information">
                            <field name="name"/>
                            <field name="slug"/>
                            <field name="ui_crm_required_phone"/>
                            <field name="ui_crm_required_email"/>
                        </group>
                        <group string="Line Setting">
                            <field name="partner_line_liff_id"/>
                            <field name="partner_line_channel_access_token"/>
                        </group>
                    </group>

                    <notebook>
                          <page string="UI Config">
                            <group>
                                <field name="ui_background_color"/>
                                <field name="ui_background_white_color"/>
                                <field name="ui_primary_color"/>
                                <field name="ui_secondary_color"/>

                                <field name="ui_text_color"/>
                                <field name="ui_text_white_color"/>
                                <field name="ui_text_gray_color"/>
                                <field name="ui_text_success_color"/>
                                <field name="ui_text_error_color"/>

                                <field name="ui_button_color"/>
                                <field name="ui_button_text_color"/>

                                <field name="ui_welcome_title"/>
                            </group>
                        </page>
                        <page string="UI Custom Fields">
                            <field name="ui_custom_field_ids" nolabel="1">
                                <list editable="bottom">
                                    <field name="key"/>
                                    <field name="value"/>
                                </list>
                            </field>
                        </page>
                        <page string="Currencies">
                            <field name="currency_ids" nolabel="1">
                                <list editable="bottom" delete="0">
                                    <field name="name"/>
                                    <field name="is_default"/>
                                </list>
                            </field>
                        </page>
                        <page string="Redeem QR">
                            <field name="point_redeem_ids" nolabel="1">
                                <list delete="0">
                                    <field name="name"/>
                                    <field name="currency_id"/>
                                    <field name="value"/>
                                    <field name="type"/>
                                    <field name="expiration_date"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                        <page string="Coupons">
                            <field name="coupon_ids" nolabel="1">
                                <list delete="0">
                                    <field name="name"/>
                                    <field name="currency_id"/>
                                    <field name="value"/>
                                    <field name="start_time"/>
                                    <field name="end_time"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids" options="{'post_refresh': 'recipients'}"/>
                </chatter>
            </form>
        </field>
    </record>
</odoo>
