<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_portal_api_key_wizard_form" model="ir.ui.view">
        <field name="name">partner.portal.api.key.wizard.form</field>
        <field name="model">partner.portal.api.key.wizard</field>
        <field name="arch" type="xml">
            <form string="Portal API Key">
                <group>
                    <field name="user_id"/>
                    <field name="api_key" widget="CopyClipboardChar"/>
                </group>
                <div class="alert alert-warning" role="alert">
                    Copy this API key now. It will not be shown again.
                    Use it in the <code>X-api-key</code> request header.
                </div>
                <footer>
                    <button string="Close" class="btn-primary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
