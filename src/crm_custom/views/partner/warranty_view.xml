<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_warranty_search" model="ir.ui.view">
        <field name="name">partner.warranty.search</field>
        <field name="model">partner.warranty</field>
        <field name="arch" type="xml">
            <search>
                <field name="serial_number"/>
                <field name="receipt_number"/>
                <field name="user_id"/>
                <field name="product_id"/>
                <field name="status_id"/>
                <group expand="0" string="Group By">
                    <filter name="group_status" string="Status" context="{'group_by': 'status_id'}"/>
                    <filter name="group_user" string="Member" context="{'group_by': 'user_id'}"/>
                    <filter name="group_product" string="Product" context="{'group_by': 'product_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_partner_warranty_list" model="ir.ui.view">
        <field name="name">partner.warranty.list</field>
        <field name="model">partner.warranty</field>
        <field name="arch" type="xml">
            <list create="false" delete="false">
                <field name="submitted_date"/>
                <field name="user_id"/>
                <field name="product_id"/>
                <field name="serial_number"/>
                <field name="receipt_number"/>
                <field name="contributor_id"/>
                <field name="purchase_date"/>
                <field name="status_id"/>
                <field name="partner_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_partner_warranty_form" model="ir.ui.view">
        <field name="name">partner.warranty.form</field>
        <field name="model">partner.warranty</field>
        <field name="arch" type="xml">
            <form create="false">
                <sheet>
                    <group>
                        <group string="Registration">
                            <field name="partner_id" readonly="1"/>
                            <field name="user_id" readonly="1"/>
                            <field name="product_id" readonly="1"/>
                            <field name="serial_number" readonly="1"/>
                            <field name="receipt_number" readonly="1"/>
                            <field name="contributor_id" readonly="1"/>
                            <field name="purchase_date" readonly="1"/>
                            <field name="submitted_date" readonly="1"/>
                        </group>
                        <group string="Status">
                            <field name="status_id"/>
                        </group>
                    </group>
                    <group string="Receipt Image">
                        <field name="receipt_image_file" widget="image" nolabel="1" readonly="1" options="{'size': [320, 320]}"/>
                        <field name="receipt_image" invisible="1"/>
                    </group>
                    <separator string="Portal Comments"/>
                    <field name="comment_ids" nolabel="1" readonly="1">
                        <list create="0" delete="0" edit="0">
                            <field name="create_date"/>
                            <field name="author_name"/>
                            <field name="body"/>
                        </list>
                    </field>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids" options="{'post_refresh': 'recipients'}"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="action_partner_warranty" model="ir.actions.act_window">
        <field name="name">Warranty Registrations</field>
        <field name="res_model">partner.warranty</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_partner_warranty_search"/>
    </record>
</odoo>
