<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_otp_model_form" model="ir.ui.view">
        <field name="name">crm.otp.form</field>
        <field name="model">crm.otp</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="type"/>
                        <field name="key" readonly="1"/>
                        <field name="key_id" readonly="1"/>
                        <field name="otp" readonly="1"/>
                        <field name="ref" readonly="1"/>
                        <field name="expiry"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
