<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_user_model_form" model="ir.ui.view">
        <field name="name">crm.user.form</field>
        <field name="model">crm.user</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <div class="oe_title">
                                <div class="text-muted" invisible="display_name == '' or not display_name">User</div>
                                <h1 invisible="not active or display_name == '' or not display_name">
                                    <field name="display_name" readonly="1"/>
                                </h1>
                                <h1 class="text-decoration-line-through text-muted" invisible="active or display_name == '' or not display_name">
                                    <field name="display_name" readonly="1"/>
                                </h1>
                            </div>
                        </group>
                    </group>

                    <group>
                        <field name="partner_id" readonly="1"/>
                    </group>

                    <group>
                        <group string="General Information">
                            <field name="picture_preview" nolabel="1" widget="html" readonly="1"/>
                            <field name="line_user_id" readonly="1"/>
                            <field name="display_name" readonly="1"/>
                            <field name="email" readonly="1"/>
                            <field name="phone" readonly="1"/>
                            <field name="is_email_verified" readonly="1"/>
                            <field name="is_phone_verified" readonly="1"/>
                        </group>
                    </group>

                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids" options="{'post_refresh': 'recipients'}"/>
                </chatter>
            </form>
        </field>
    </record>
</odoo>
