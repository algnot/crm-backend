<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_user_model_form" model="ir.ui.view">
        <field name="name">crm.user.form</field>
        <field name="model">crm.user</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_add_point" string="Add Point" type="object" class="btn-primary" icon="fa-plus"/>
                    <button name="action_add_coupon" string="Add Coupon" type="object" class="btn-secondary" icon="fa-ticket"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <group>
                        <group>
                            <field name="picture_preview" nolabel="1" widget="html" readonly="1"/>
                        </group>
                        <group>
                            <div class="oe_title">
                                <div class="text-muted" invisible="display_name == '' or not display_name">User</div>
                                <h1 invisible="not active or display_name == '' or not display_name">
                                    <field name="display_name" readonly="1"/>
                                </h1>
                                <h1 class="text-decoration-line-through text-muted" invisible="active or display_name == '' or not display_name">
                                    <field name="display_name" readonly="1"/>
                                </h1>
                            </div>
                            <field name="partner_id" readonly="1"/>
                            <field name="tier_id" readonly="1"/>
                            <field name="line_user_id" readonly="1"/>
                        </group>
                    </group>

                    <group string="Contact">
                        <group>
                            <field name="email"/>
                            <field name="is_email_verified"/>
                        </group>
                        <group>
                            <field name="phone"/>
                            <field name="is_phone_verified"/>
                        </group>
                        <group>
                            <field name="birth_date"/>
                            <field name="gender"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Points">
                            <group string="Balance Summary">
                                <field name="point_balance_display" readonly="1" nolabel="1"/>
                            </group>
                            <field name="point_ids" nolabel="1" readonly="1">
                                <list delete="0" create="0" edit="0"
                                      decoration-success="type == 'earn'"
                                      decoration-danger="type == 'burn'"
                                      decoration-warning="type == 'transfer'">
                                    <field name="given_date"/>
                                    <field name="type"/>
                                    <field name="currency_id"/>
                                    <field name="value"/>
                                    <field name="name"/>
                                    <field name="admin_note" optional="show"/>
                                    <field name="expiration_date" optional="hide"/>
                                </list>
                                <form>
                                    <sheet>
                                        <div class="oe_title">
                                            <div class="text-muted">Point Transaction</div>
                                            <h1>
                                                <field name="name" readonly="1"/>
                                            </h1>
                                        </div>
                                        <group>
                                            <group string="Transaction">
                                                <field name="currency_id" readonly="1"/>
                                                <field name="type" readonly="1"/>
                                                <field name="value" readonly="1"/>
                                            </group>
                                            <group string="Dates">
                                                <field name="given_date" readonly="1"/>
                                                <field name="expiration_date" readonly="1"/>
                                            </group>
                                        </group>
                                        <group string="Admin Note" invisible="not admin_note">
                                            <field name="admin_note" readonly="1" nolabel="1"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                        <page string="Coupons">
                            <group>
                                <group string="Coupon Summary">
                                    <field name="coupon_count" readonly="1"/>
                                    <field name="active_coupon_count" readonly="1"/>
                                </group>
                                <group>
                                    <field name="coupon_summary_display" readonly="1"/>
                                </group>
                            </group>
                            <field name="coupon_ids" nolabel="1" readonly="1">
                                <list delete="0" create="0" edit="0"
                                      decoration-muted="is_used"
                                      decoration-success="not is_used">
                                    <field name="acquired_date"/>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="value"/>
                                    <field name="currency_id"/>
                                    <field name="is_used"/>
                                    <field name="used_date" optional="show"/>
                                    <field name="admin_note" optional="show"/>
                                    <field name="expiration_date" optional="hide"/>
                                </list>
                                <form>
                                    <sheet>
                                        <widget name="web_ribbon" title="Used" bg_color="text-bg-secondary" invisible="not is_used"/>
                                        <widget name="web_ribbon" title="Active" bg_color="text-bg-success" invisible="is_used"/>
                                        <div class="oe_title">
                                            <div class="text-muted">User Coupon</div>
                                            <h1>
                                                <field name="name" readonly="1"/>
                                            </h1>
                                            <h3>
                                                <field name="code" readonly="1"/>
                                            </h3>
                                        </div>
                                        <group>
                                            <group string="Coupon">
                                                <field name="coupon_id" readonly="1"/>
                                                <field name="currency_id" readonly="1"/>
                                                <field name="value" readonly="1"/>
                                                <field name="is_used" readonly="1"/>
                                            </group>
                                            <group string="Dates">
                                                <field name="acquired_date" readonly="1"/>
                                                <field name="expiration_date" readonly="1"/>
                                                <field name="used_date" readonly="1" invisible="not is_used"/>
                                            </group>
                                        </group>
                                        <group string="Admin Note" invisible="not admin_note">
                                            <field name="admin_note" readonly="1" nolabel="1"/>
                                        </group>
                                    </sheet>
                                </form>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids" options="{'post_refresh': 'recipients'}"/>
                </chatter>
            </form>
        </field>
    </record>
</odoo>
