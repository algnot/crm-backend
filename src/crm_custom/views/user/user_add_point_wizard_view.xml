<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_user_add_point_wizard_form" model="ir.ui.view">
        <field name="name">crm.user.add.point.wizard.form</field>
        <field name="model">crm.user.add.point.wizard</field>
        <field name="arch" type="xml">
            <form string="Add Point">
                <group>
                    <field name="user_id"/>
                    <field name="partner_id"/>
                    <field name="currency_id" domain="[('partner_id', '=', partner_id)]"/>
                    <field name="value"/>
                    <field name="type"/>
                    <field name="expiration_date"/>
                    <field name="note" placeholder="ระบุหมายเหตุ (จำเป็น)"/>
                </group>
                <footer>
                    <button name="action_add_point" string="Add Point" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
